{
  "name": "humita-client",
  "version": "1.0.0",
  "description": "Client de Minecraft modular desarrollado con Electron",
  "main": "src/main.js",
  "author": "Humita Dev",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:publish": "electron-builder --publish always"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.3.9",
    "extract-zip": "^2.0.1",
    "keytar": "^7.9.0",
    "msmc": "^4.1.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "globals": "^17.5.0"
  },
  "build": {
    "appId": "dev.humita.Client",
    "productName": "Humita Client",
    "publish": {
      "provider": "github",
      "owner": "eLcompletoxd",
      "repo": "Humita-Launcher"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/base.png"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}