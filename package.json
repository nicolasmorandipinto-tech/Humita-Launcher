{
  "name": "humita-launcher",
  "version": "1.0.0",
  "description": "Launcher de Minecraft modular desarrollado con Electron",
  "main": "src/main.js",
  "author": "Humita Dev",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-fetch": "^3.3.2",
    "extract-zip": "^2.0.1",
    "msmc": "^4.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "dev.humita.launcher",
    "productName": "Humita Launcher",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
